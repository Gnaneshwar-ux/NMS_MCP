{
  "name": "ssh-mcp-server",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade MCP server for persistent SSH PTY shells and Oracle DB diagnostics.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ssh-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "npm run build && node --test \"test/*.test.js\"",
    "coverage": "npm run build && node --test --experimental-test-coverage \"test/*.test.js\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "oracledb": "^6.10.0",
    "ssh2": "^1.15.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ssh2": "^1.11.0",
    "@types/uuid": "^9.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
